{
  "entities": {
    "userSettings": {
      "title": "User Settings",
      "description": "Stores user physical data and hydration goals",
      "type": "object",
      "properties": {
        "weight": { "type": "number", "description": "User weight in kg" },
        "dailyGoal": { "type": "number", "description": "Calculated daily goal in ml" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["weight", "dailyGoal"]
    },
    "waterLog": {
      "title": "Water Log",
      "description": "A single entry of water consumption",
      "type": "object",
      "properties": {
        "amount": { "type": "number", "description": "Amount in ml" },
        "timestamp": { "type": "string", "format": "date-time" },
        "date": { "type": "string", "description": "YYYY-MM-DD format for easy querying" }
      },
      "required": ["amount", "timestamp", "date"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "userSettings",
      "description": "User specific settings"
    },
    "users/{userId}/logs/{logId}": {
      "schema": "waterLog",
      "description": "Individual water intake logs for a user"
    }
  }
}
