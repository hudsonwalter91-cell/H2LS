{
  "entities": {
    "UserSettings": {
      "title": "User Settings",
      "description": "User hydration settings and goals",
      "type": "object",
      "properties": {
        "weight": { "type": "number" },
        "dailyGoal": { "type": "number" },
        "hydrationLevel": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["weight", "dailyGoal", "hydrationLevel", "updatedAt"]
    },
    "WaterLog": {
      "title": "Water Log",
      "description": "A single entry of water consumption",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "amount": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "date": { "type": "string" }
      },
      "required": ["id", "amount", "timestamp", "date"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserSettings",
      "description": "User settings document"
    },
    "/users/{userId}/logs/{logId}": {
      "schema": "WaterLog",
      "description": "Individual water consumption logs"
    }
  }
}
