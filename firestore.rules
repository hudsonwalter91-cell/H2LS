rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (matches auth.uid)
    // Fields:
    //   - weight: number (required)
    //   - dailyGoal: number (required)
    //   - hydrationLevel: number (required)
    //   - updatedAt: string (ISO date)
    //
    // Collection: users/{userId}/logs
    // Document ID: {logId}
    // Fields:
    //   - id: string (required)
    //   - amount: number (required)
    //   - timestamp: string (ISO date)
    //   - date: string (YYYY-MM-DD)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUserSettings(data) {
      return data.keys().hasAll(['weight', 'dailyGoal', 'hydrationLevel', 'updatedAt']) &&
             data.weight is number && data.weight > 0 &&
             data.dailyGoal is number && data.dailyGoal > 0 &&
             data.hydrationLevel is number && data.hydrationLevel >= 1 && data.hydrationLevel <= 3 &&
             data.updatedAt is string;
    }

    function isValidWaterLog(data) {
      return data.keys().hasAll(['id', 'amount', 'timestamp', 'date']) &&
             data.id is string &&
             data.amount is number && data.amount > 0 &&
             data.timestamp is string &&
             data.date is string;
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidUserSettings(request.resource.data);
      
      match /logs/{logId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidWaterLog(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
